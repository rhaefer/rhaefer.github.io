ui <-dashboardPage(skin="green",
dashboardHeader(title="Progress Reports",titleWidth = 300),
dashboardSidebar(disable=T),
dashboardBody(tags$head(tags$style(HTML('
.main-header .logo {
font-family: "Georgia", Times, "Times New Roman", serif;
font-weight: bold;
font-size: 24px;} '))) ,
fluidRow(
box(width=7,title="Milestones",solidHeader = TRUE,collapsible = TRUE, status="primary",plotOutput("barchart", height = 250)),
box(width=2,title="Years",solidHeader = TRUE,collapsible = TRUE, status="warning",plotOutput("barchart1", height = 250)),
box(width=3,selectInput('n', 'year', unique(data_completions$year), selected="all years",multiple=FALSE))),
fluidRow(
box(width=9,leafletOutput("mymap", width=600, height=500)))
))
server <- function(input, output) {
output$barchart <- renderPlot({
ggplot(data_completions[data_completions$year==input$n,], aes(milestone, count, fill=milestone)) +
geom_bar(stat="identity") +theme_economist() +
theme(legend.position="none", axis.text.y=element_text(hjust=1, size=14, face="bold"), axis.text.x=element_text( size=14, face="bold"),
axis.title.y=element_blank())+
scale_fill_manual(values = c("#91268F", "#F05A28", "#8CC63E","#00A7A0", "black", "#A4A1A0"))+coord_flip() +
ylab("Number of Projects")
})
output$barchart1 <- renderPlot({
ggplot(data_completions[data_completions$year==input$n,], aes(year, count, fill=milestone)) +
geom_bar(stat="identity") +theme_economist() +
theme(legend.position = "none",axis.title.x=element_blank(), axis.text.y=element_text(hjust=1, size=14, face="bold"),
axis.text.x=element_text( size=14, face="bold")) +
scale_fill_manual(values = c("#91268F", "#F05A28", "#8CC63E","#00A7A0", "black", "#A4A1A0")) +
ylab("Number of Projects")
})
output$mymap <- renderLeaflet({
leaflet() %>%
fitBounds(-122.2, 47.187, -122.4, 47.932)%>%
addProviderTiles("Stamen.TonerLite", group = "Toner Lite") %>%
addPolylines(data=d, weight=4)
})
}
shinyApp(ui, server)
