data<-read.xlsx("final_PR_data_RH.xlsx", sheetName='Sheet1')
data$tip_id<-toupper(data$tip_id)
data$tip_id<-str_replace_all(data$tip_id, fixed(" "), "")
data$milestone<-gsub("Contract Awarded", "Under Construction", data$milestone)
data$milestone<-gsub("Design Underway  & ROW Certified", "Design Underway & ROW Certified", data$milestone)
data$milestone<-gsub("Design Underway & ROW Certified", "Design Underway & Right of Way Completed", data$milestone)
data<-data[data$milestone != "Completed",]
data<-data[data$milestone != "Planning Study Completed",]
data$year<-substr(data$m_y, 1, 4)
data<-data[rownames(data) != "72", ]
data$milestone<-gsub("Design Underway & Right of Way Completed", "Right of Way Completed", data$milestone)
data$milestone<-gsub("ROW Completed", "Right of Way Completed", data$milestone)
data_completions<-data.frame(data%>% group_by(year, milestone) %>% summarise(count=n()))
new_data<-data.frame(data_completions %>% group_by(milestone) %>% summarise(count=sum(count)) %>% mutate(year="all years"))
new_data<-new_data[c("year", "milestone", "count")]
data_completions<-rbind(data_completions, new_data)
data_completions<-arrange(data_completions, desc(year))
b<- shapefile("PR_shapefile_2.shp")
d<- shapefile("PR_Mapped_Projects2.shp")
c <- readShapePoly("PR_shapefile_2")
e <- readShapePoly("PR_Mapped_Projects2")
